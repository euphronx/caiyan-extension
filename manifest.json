{
  "manifest_version": 3,
  "name": "xiaoce.fun helper",
  "description": "pass all the daily tasks on xiaoce.fun",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://www.bilibili.com/*", "https://m.bilibili.com/*"]
    }
  ],
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "host_permissions": ["https://xiaoce.fun/*"]
}
